# VC Info Agent — 环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# YouTube Data API v3 Key（可选，不填则跳过 YouTube 采集）
# 获取方式：https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# LLM API Key（必填，默认使用 DeepSeek）
# 获取方式：https://platform.deepseek.com/api_keys
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 飞书 Webhook（可选，不填则只输出 Markdown 文件）
# 创建方式：飞书群 → 设置 → 群机器人 → 自定义机器人 → 复制 Webhook 地址
FEISHU_WEBHOOK=
